# ─── WALLET ─────────────────────────────────────────────────────────────────
# Your MetaMask wallet private key (64 hex chars, WITHOUT 0x or WITH 0x)
PRIVATE_KEY=0x_your_64_char_private_key_here

# Wallet address that RECEIVES the USDC micropayments from sub-agents
# Can be the same wallet that pays (self-pay for testing)
RECIPIENT=0x_your_wallet_address_here

# Google Gemini API key — get free at aistudio.google.com → API Keys
GEMINI_API_KEY=AIza_your_gemini_key_here

# ─── MULTI-LLM FALLBACKS ───────────────────────────────────────────────────
# OpenRouter — multi-provider LLM gateway
OPENROUTER_API_KEY=your_openrouter_key_here

# Hugging Face — free inference API
HUGGINGFACE_API_KEY=your_huggingface_key_here

# ─── DATA APIs (free) ────────────────────────────────────────────────────────
# NewsAPI — free 500 req/day — sign up at newsapi.org (instant approval)
NEWS_API_KEY=your_newsapi_key_here

# The Guardian — free unlimited — sign up at open-platform.theguardian.com
# (optional — fallback if NewsAPI fails)
GUARDIAN_API_KEY=your_guardian_key_here

# ─── BLOCKCHAIN ──────────────────────────────────────────────────────────────
# Deployed AgentRegistry.sol contract address on Avalanche Fuji
# Fill in AFTER running: npx hardhat run scripts/deploy.js --network fuji
REGISTRY_ADDRESS=0x_fill_after_deploying_contract

# ─── SERVER ──────────────────────────────────────────────────────────────────
# Port for x402 gateway + dashboard server (default: 3001)
PORT=3001
